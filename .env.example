# Скопируй этот файл в .env и заполни своими значениями:
#     cp .env.example .env
# Файл .env НИКОГДА не попадает в git (он уже в .gitignore) — там твои секреты.

# ===================== ТЕЛЕГРАМ-БОТ =====================
# Токен бота. Получить у @BotFather в Telegram: команда /newbot.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Твой Telegram ID (числом) — это «администратор». Можно несколько через запятую.
# Свой ID узнать у бота @userinfobot.
ADMIN_IDS=123456789

# ===================== БАЗА ДАННЫХ =====================
# Файл базы SQLite. Создастся сам при первом запуске. Менять не обязательно.
DB_PATH=vpn_service.db

# ===================== ТАРИФЫ (в рублях за дни) =====================
# Формат: дни:цена через запятую. Пример ниже = 30 дней за 150₽, 90 за 400₽, 180 за 700₽.
PLANS=30:150,90:400,180:700

# Сколько гигабайт трафика даём по умолчанию на подписку (0 = безлимит).
DEFAULT_TRAFFIC_LIMIT_GB=100
# Ограничение скорости по умолчанию, мегабит/с (0 = без ограничения).
DEFAULT_SPEED_LIMIT_MBIT=50
# Какие протоколы разрешены по умолчанию (через запятую): all, web, no_torrent.
#   all        — разрешаем всё
#   web        — только веб (порты 80/443) и DNS
#   no_torrent — всё, кроме типичных торрент-портов
DEFAULT_PROTOCOL_PROFILE=all

# ===================== ОПЛАТА =====================
# Способ приёма денег: manual | yookassa | antarctic
#   manual    — клиент платит сам, ты подтверждаешь кнопкой в боте (рекомендую для старта)
#   yookassa  — авто-приём СБП через ЮKassa (нужен договор с ЮKassa)
#   antarctic — кошелёк Antarctic Wallet (заглушка, включится когда будет API)
PAYMENT_PROVIDER=manual

# --- Реквизиты для ручной оплаты (показываются клиенту) ---
# Номер телефона для перевода по СБП.
SBP_PHONE=+7 900 000-00-00
# Имя получателя (как в банке) и банк — чтобы клиент не ошибся.
SBP_RECEIVER=Иван И., Сбербанк
# Адрес/идентификатор кошелька Antarctic Wallet (если принимаешь и так).
ANTARCTIC_WALLET=

# --- ЮKassa (нужно только если PAYMENT_PROVIDER=yookassa) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ===================== VPN-СЕРВЕР (WireGuard / AmneziaWG) =====================
# Имя сетевого интерфейса VPN. У обычного WireGuard это wg0, у AmneziaWG часто awg0.
# Посмотреть можно командой:  sudo wg show   (или  sudo awg show)
WG_INTERFACE=wg0
# Команда управления: wg для WireGuard, awg для AmneziaWG.
WG_CMD=wg
# Путь к конфигу сервера, куда дописываются клиенты (peers).
WG_CONFIG_PATH=/etc/wireguard/wg0.conf

# Публичный ключ СЕРВЕРА (его получает каждый клиент). Узнать:  sudo wg show wg0 public-key
WG_SERVER_PUBLIC_KEY=
# Внешний адрес и порт сервера, куда подключаются клиенты. Пример: 1.2.3.4:51820
WG_SERVER_ENDPOINT=1.2.3.4:51820
# Внутренняя подсеть VPN. Клиентам будут выдаваться адреса из неё (10.8.0.2, .3, ...).
WG_SUBNET=10.8.0.0/24
# DNS, который пропишется клиентам.
WG_DNS=1.1.1.1

# ===================== ОГРАНИЧЕНИЕ ТРАФИКА (tc / nftables) =====================
# Сетевой интерфейс сервера, смотрящий в интернет (НЕ vpn). Обычно eth0 или ens3.
# Посмотреть:  ip route get 8.8.8.8   — там будет "dev <имя>".
WAN_INTERFACE=eth0
# Реально применять команды tc/nftables на сервере? true — да, false — только показывать,
# что было бы выполнено (безопасно для первых тестов и для запуска НЕ на сервере).
APPLY_TRAFFIC_RULES=false

# ===================== ВЕБ-ПАНЕЛЬ =====================
# Логин и пароль для входа в админ-панель в браузере. ОБЯЗАТЕЛЬНО смени!
WEB_PANEL_USER=admin
WEB_PANEL_PASSWORD=поменяй_меня
# На каком порту открывать панель. Откроется по адресу http://IP_СЕРВЕРА:8080
WEB_PANEL_PORT=8080
