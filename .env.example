# Скопируй этот файл в .env и заполни своими ключами.
# Файл .env НИКОГДА не должен попадать в git (он уже в .gitignore).

# ===== KuCoin API =====
# Получить на https://www.kucoin.com/account/api
# Важно: для фьючерсов нужны отдельные ключи (futures-api.kucoin.com)
KUCOIN_API_KEY=твой_ключ
KUCOIN_API_SECRET=твой_секрет
KUCOIN_API_PASSPHRASE=твой_пароль_от_API

# ===== ИИ =====
# Берём один из двух (Claude рекомендую — лучше анализирует тексты)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ===== Telegram =====
# Получить на https://my.telegram.org/apps
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=твой_hash
TELEGRAM_PHONE=+79991234567

# Каналы, которые читаем (через запятую, без @)
TELEGRAM_CHANNELS=cryptonews,binance_announcements

# ===== Режим работы =====
# true = торгуем настоящими деньгами, false = только симуляция (paper trading)
LIVE_TRADING=false
